# ── AI provider (use whatever you want) ──────────────────────────────────────
# Pick one. Default is anthropic. Override any model with AI_MODEL.
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
# AI_PROVIDER=openai   ; OPENAI_API_KEY=sk-...            (default model gpt-4o-mini)
# AI_PROVIDER=gemini   ; GEMINI_API_KEY=...               (default model gemini-2.0-flash)
# AI_PROVIDER=local    ; AI_BASE_URL=http://localhost:11434/v1 ; AI_MODEL=llama3.1
#                        (Ollama or any OpenAI-compatible server; AI_API_KEY optional)
# AI_MODEL=            # optional: force a specific model for the chosen provider

# ── Notifications (optional) ─────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=
EMAIL_SENDER=you@gmail.com
EMAIL_PASSWORD=your-gmail-app-password
EMAIL_TO=you@gmail.com

# ── Tracker (only if you deployed the dashboard) ─────────────────────────────
TRACKER_URL=
TRACKER_CLIENT_ID=
TRACKER_CLIENT_SECRET=
